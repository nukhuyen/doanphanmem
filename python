<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Đăng ký tài khoản</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
        background: linear-gradient(135deg, #0d6efd, #4dabf7);
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .login-container { width: 100%; max-width: 450px; padding: 20px; }

    .school-header { text-align: center; margin-bottom: 30px; color: white; }
    .school-header h1 {
        font-weight: 800; font-size: 32px; margin-bottom: 8px;
        text-shadow: 2px 2px 4px rgba(0,0,0,.2);
    }
    .school-header p { font-size: 16px; opacity: .95; }

    .login-card {
        background: white; border-radius: 20px;
        box-shadow: 0 20px 60px rgba(0,0,0,.3); padding: 40px;
    }
    .login-card h3 {
        text-align: center; color: #0d6efd;
        font-weight: 700; margin-bottom: 30px; font-size: 24px;
    }

    .form-group { margin-bottom: 20px; }
    .form-group label {
        display: block; margin-bottom: 10px;
        color: #333; font-weight: 600; font-size: 15px;
    }

    .form-control {
        width: 100%; padding: 14px 16px;
        border: 2px solid #e0e0e0; border-radius: 10px;
        font-size: 15px; transition: all .3s ease; background-color: #f8f9fa;
    }
    .form-control:focus {
        background-color: white; border-color: #0d6efd;
        box-shadow: 0 0 0 3px rgba(13,110,253,.15); outline: none;
    }
    .form-control::placeholder { color: #999; }

    .hint { font-size: 12px; color: #999; margin-top: 6px; }

    .btn-login {
        width: 100%; padding: 14px;
        background: linear-gradient(135deg, #0d6efd, #4dabf7);
        color: white; border: none; border-radius: 10px;
        font-size: 16px; font-weight: 600; cursor: pointer;
        transition: all .3s ease; margin-top: 10px; margin-bottom: 15px;
    }
    .btn-login:hover { transform: translateY(-2px); box-shadow: 0 10px 20px rgba(13,110,253,.3); }
    .btn-login:active { transform: translateY(0); }

    /* Divider */
    .divider {
        display: flex; align-items: center; gap: 12px;
        margin: 4px 0 16px; color: #bbb; font-size: 13px;
    }
    .divider::before, .divider::after {
        content: ''; flex: 1; height: 1px; background: #e0e0e0;
    }

    /* Back to login button */
    .btn-back {
        display: block; width: 100%; padding: 13px;
        background: white; color: #0d6efd;
        border: 2px solid #0d6efd; border-radius: 10px;
        font-size: 15px; font-weight: 600;
        text-align: center; text-decoration: none;
        transition: all .3s ease;
    }
    .btn-back:hover {
        background: #0d6efd; color: white;
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(13,110,253,.3);
    }

    .alert { border-radius: 10px; border: none; margin-bottom: 20px; font-size: 14px; }
    .alert-danger  { background-color: #f8d7da; color: #721c24; }
    .alert-success { background-color: #d4edda; color: #155724; }
</style>
</head>
<body>

<div class="login-container">
    <div class="school-header">
        <h1>🎓 HỆ THỐNG ĐĂNG KÝ HỌC PHẦN</h1>
        <p>Cổng thông tin sinh viên</p>
    </div>

    <div class="login-card">
        <h3>Tạo tài khoản mới</h3>

        {% with messages = get_flashed_messages(with_categories=true) %}
            {% if messages %}
                {% for category, message in messages %}
                    {% if category == 'success' %}
                        <div class="alert alert-success">{{ message }}</div>
                    {% else %}
                        <div class="alert alert-danger">{{ message }}</div>
                    {% endif %}
                {% endfor %}
            {% endif %}
        {% endwith %}

        <form method="post" action="{{ url_for('register') }}" onsubmit="return checkForm()">

            <div class="form-group">
                <label for="username">Tên đăng nhập</label>
                <input type="text" id="username" name="username"
                       class="form-control"
                       placeholder="Nhập tên đăng nhập (tối thiểu 3 ký tự)"
                       minlength="3" required autofocus>
                <div class="hint">Chỉ dùng chữ cái, số và dấu gạch dưới</div>
            </div>

            <div class="form-group">
                <label for="password">Mật khẩu</label>
                <input type="password" id="password" name="password"
                       class="form-control"
                       placeholder="Nhập mật khẩu (tối thiểu 6 ký tự)"
                       minlength="6" required>
            </div>

            <div class="form-group">
                <label for="confirm">Xác nhận mật khẩu</label>
                <input type="password" id="confirm" name="confirm"
                       class="form-control"
                       placeholder="Nhập lại mật khẩu"
                       minlength="6" required>
            </div>

            <button type="submit" class="btn-login">✏️ Đăng ký</button>
        </form>

        <!-- Quay lại đăng nhập -->
        <div class="divider">hoặc</div>
        <a href="{{ url_for('login') }}" class="btn-back">
            ← Quay lại đăng nhập
        </a>

    </div>
</div>

<script>
    function checkForm() {
        var pw  = document.getElementById('password').value;
        var pw2 = document.getElementById('confirm').value;
        if (pw !== pw2) {
            alert('Mật khẩu xác nhận không khớp!');
            document.getElementById('confirm').focus();
            return false;
        }
        return true;
    }
</script>

</body>
</html>